BOT_CONTAINER_NAME=bot_container_name
BOT_IMAGE_NAME=botimage_name
BOT_NAME=mybotname
BOT_MODE=1
BOT_TOKEN=123456:Your-TokEn_ExaMple
ADMINS=123456,654321
USE_REDIS=False

# Uptime limit in hours (if you need to restart bot daily, for example to keep running on free pythonanywhere.com account)
UPTIME_LIMIT=0

# Output data directory for trace calculation results (PNG, .path files)
# Can be absolute or relative path. Relative paths resolve from current working directory.
OUTPUT_DATA_DIR=output_data

# Your https://rapidapi.com/toursprung-toursprung-default/api/maptoolkit/playground/apiendpoint_6da0665d-de84-4227-a41d-accd9c7974d7 API key
ELEVATION_API_URL=https://maptoolkit.p.rapidapi.com/elevation
ELEVATION_API_KEY=123456Your-API-Key_ExaMple

# Your https://www.ngdc.noaa.gov/geomag/calculators/magcalc.shtml#declination API key
DECLINATION_API_URL=https://www.ngdc.noaa.gov/geomag-web/calculators/calculateDeclination
DECLINATION_API_KEY=aBC123

# Set the logging level for the application.
# Possible values: CRITICAL, ERROR, WARNING, INFO, DEBUG, NOTSET
LOGGING_LEVEL=INFO

# Enable debug mode (overrides LOGGING_LEVEL if set to True)
DEBUG=False

CLIMATE_ZONES_FILE_ID=SampleID123

# Comment if not required
# PROXY_URL=http://proxy.server:3128
